-cp ../haxe.compilerdev.reference/reflaxe/src
-cp src
-cp fixtures/wphx-php/src
-main wphx.fixtures.compiler.php.include.IncludeSideEffectEntry
-D wphx_php_output=build/wphx-php/include-side-effects/generated
-D wphx_php_manifest=build/wphx-php/include-side-effects/generated/wphx-php-emission.v1.json
-D wphx_php_profile=wordpress
--macro wphx.compiler.php.CompilerInit.Start()
