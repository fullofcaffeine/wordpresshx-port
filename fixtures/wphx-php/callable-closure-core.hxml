-cp ../haxe.compilerdev.reference/reflaxe/src
-cp src
-cp fixtures/wphx-php/src
-main wphx.fixtures.compiler.php.core.CallableClosureEntry
-D wphx_php_output=build/wphx-php/callable-closure-core/generated
