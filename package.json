{
  "name": "wordpress-hx",
  "private": true,
  "version": "0.0.0",
  "description": "Experimental WordPress 7.0 and Gutenberg migration program using Haxe, Codex, and Beads.",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "format:haxe": "bash scripts/lint/haxe-format.sh --write",
    "format:haxe:check": "bash scripts/lint/haxe-format.sh",
    "security:gitleaks": "bash scripts/security/run-gitleaks.sh",
    "security:gitleaks:staged": "bash scripts/security/run-gitleaks.sh --staged",
    "hooks:install": "bash scripts/hooks/install.sh",
    "baseline:validate": "node tools/baseline/validate-policy.mjs",
    "beads:validate": "node tools/beads/validate-graph.mjs",
    "beads:seed": "node tools/beads/seed-prd-issues.mjs --check",
    "beads:seed:apply": "node tools/beads/seed-prd-issues.mjs --apply",
    "dashboard:build": "node tools/dashboard/build-dashboard.mjs",
    "dashboard": "node tools/dashboard/parity-dashboard.mjs",
    "dashboard:check": "node tools/dashboard/check-dashboard.mjs",
    "inventory": "node tools/inventory/wphx-inventory.mjs",
    "inventory:validate": "node tools/inventory/validate-inventory.mjs",
    "inventory:check": "node tools/inventory/check-determinism.mjs && npm run inventory:validate",
    "license:provenance": "node tools/license/audit-provenance.mjs",
    "license:provenance:check": "node tools/license/audit-provenance.mjs --check",
    "oracle:vanilla": "node tools/oracle/vanilla-oracle.mjs",
    "php:facade:f1": "node tools/php-facade/run-f1-global-function.mjs",
    "php:facade:f1:check": "node tools/php-facade/run-f1-global-function.mjs --check",
    "php:facade:f2": "node tools/php-facade/run-f2-references.mjs",
    "php:facade:f2:check": "node tools/php-facade/run-f2-references.mjs --check",
    "php:facade:f3": "node tools/php-facade/run-f3-native-values.mjs",
    "php:facade:f3:check": "node tools/php-facade/run-f3-native-values.mjs --check",
    "php:facade:f4": "node tools/php-facade/run-f4-public-class.mjs",
    "php:facade:f4:check": "node tools/php-facade/run-f4-public-class.mjs --check",
    "php:facade:f5": "node tools/php-facade/run-f5-include-load.mjs",
    "php:facade:f5:check": "node tools/php-facade/run-f5-include-load.mjs --check",
    "php:facade:f6": "node tools/php-facade/run-f6-template-scope.mjs",
    "php:facade:f6:check": "node tools/php-facade/run-f6-template-scope.mjs --check",
    "php:facade:f7": "node tools/php-facade/run-f7-hook-kernel.mjs",
    "php:facade:f7:check": "node tools/php-facade/run-f7-hook-kernel.mjs --check",
    "php:abi": "node tools/php-abi/extract-wordpress-abi.mjs",
    "php:abi:validate": "node tools/php-abi/validate-wordpress-abi.mjs",
    "php:abi:check": "node tools/php-abi/check-determinism.mjs && npm run php:abi:validate",
    "php:smoke": "node tools/php-smoke/run-smoke.mjs",
    "php:smoke:check": "node tools/php-smoke/run-smoke.mjs --check",
    "receipts:build": "node tools/receipts/build-evidence-links.mjs",
    "receipts:validate": "node tools/receipts/validate-receipts.mjs",
    "wp:macro:bindings": "node tools/wp-macro/run-binding-validator.mjs",
    "wp:macro:bindings:check": "node tools/wp-macro/run-binding-validator.mjs --check",
    "operations:multi-agent:check": "node tools/operations/check-multi-agent-drill.mjs",
    "task-pack": "node tools/task-packs/generate-task-pack.mjs",
    "task-pack:check": "node tools/task-packs/check-task-pack.mjs",
    "precommit": "npm run format:haxe:check && npm run baseline:validate && npm run beads:seed && npm run receipts:validate && npm run security:gitleaks"
  },
  "devDependencies": {
    "php-parser": "^3.7.0",
    "playwright": "^1.61.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fullofcaffeine/wordpress-hx.git"
  }
}
